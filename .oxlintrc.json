{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "import", "promise", "oxc", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrors": "none",
        "ignoreRestSiblings": true
      }
    ],
    "import/no-unassigned-import": "off",
    "no-underscore-dangle": [
      "warn",
      {
        "allow": ["__filename", "__dirname"],
        "allowAfterThis": true,
        "enforceInMethodNames": false
      }
    ],
    "vitest/expect-expect": ["error", { "assertFunctionNames": ["expect", "request.**.expect"] }]
  },
  "ignorePatterns": ["**/dist/**", "coverage/**", "data/**", "server/public/**"]
}
