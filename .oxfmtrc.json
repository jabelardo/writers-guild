{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "printWidth": 100,
  "sortPackageJson": false,
  "ignorePatterns": [
    "package-lock.json",
    "server/package-lock.json",
    "vue_client/package-lock.json",
    "LICENSE",
    "coverage/**",
    "data/**",
    "server/public/**",
    "**/dist/**"
  ]
}
